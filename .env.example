# Google Cloud project hosting the Agent Registry + Vertex AI
GOOGLE_CLOUD_PROJECT=your-project-id

# Vertex AI region for Gemini calls. Use 'global' for global routing
# (required by some preview models, supported by all current Gemini models).
# Alternatively, set to a specific region like 'us-central1'.
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true

# Agent Registry location (often 'global'). Kept separate so it doesn't collide with Vertex.
AGENT_REGISTRY_LOCATION=global

# Maps APIs now use ADC (gcloud auth application-default login) — no key needed.
# Required APIs in your project: places.googleapis.com, routes.googleapis.com,
# and geocoding endpoints. Enable with:
#   gcloud services enable places.googleapis.com routes.googleapis.com \
#     geocoding-backend.googleapis.com --project=<your-project>

# Demo defaults
DEMO_CITY="San Francisco"
DEMO_HOME_ADDRESS="24th & Mission, San Francisco, CA"

# Set to 1 to use cached/mocked responses (useful for offline demos)
MOCK=0

# Ports for local A2A agent servers
DOG_WALKER_PORT=8001
TRIP_PLANNER_PORT=8002
